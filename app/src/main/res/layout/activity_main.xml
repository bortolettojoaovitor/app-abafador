    <?xml version="1.0" encoding="utf-8"?>
    <!-- garante que a interface não quebre em telas menores -->
    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F7F6"
        android:fillViewport="true">

        <!---empilha os elementos verticalmente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- titulo principal-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Controle de Ruído"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- CARD 1: status de conexão e leitura dos microfones -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Cabeçalho do Card: status da conexão e bateria -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- layout_weight="1" obriga este texto a ocupar o espaco inteiro,
                              empurra o texto da bateria para a direita. -->
                        <TextView
                            android:id="@+id/textoStatusConexao"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="● Desconectado"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#8470FF" />

                        <TextView
                            android:id="@+id/textoBateria"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔋 100%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#43A047" />
                    </LinearLayout>

                    <!-- Linha divisória -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- monitoramento de Ruído-->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ruído Ambiente Atual"
                        android:textSize="12sp"
                        android:textColor="#7F8C8D" />

                    <!-- O ID textoRuidoAtual é manipulado no Java para atualizar os decibéis -->
                    <TextView
                        android:id="@+id/textoRuidoAtual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="45 dB"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2: Controles dos parametros -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- controle de volume -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Volume Geral"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#34495E" />
                        <!-- valor do texto é atualizado pelo Java (id é passado na chamada no .java -->
                        <TextView
                            android:id="@+id/textoValorVolume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textSize="16sp"
                            android:textColor="#3498DB"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/barraControleVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#3498DB"
                        android:thumbTint="#3498DB"/>

                    <!-- controle de limite de decibéis -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Limite de Segurança"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#34495E" />
                        <!-- O valor do texto é atualizado  pelo Java (mesma coisa do de cima) -->
                        <TextView
                            android:id="@+id/textoValorCorteDB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85 dB"
                            android:textSize="16sp"
                            android:textColor="#E67E22"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/barraControleCorteDB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="120"
                        android:progress="85"
                        android:progressTint="#EE9A49"
                        android:thumbTint="#EE9A49"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- modos de ruido  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modos de Abafamento"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#7F8C8D"
                android:layout_marginBottom="12dp" />

            <!-- Uso do MaterialButton para arredondar bordas e retorno de clique -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoModoFoco"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Modo Foco Total"
                app:cornerRadius="12dp"
                app:backgroundTint="#5F9EA0"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoModoConforto"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Modo Conforto"
                app:cornerRadius="12dp"
                app:backgroundTint="#5F9EA0"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoModoConversa"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Modo Conversação"
                app:cornerRadius="12dp"
                app:backgroundTint="#5F9EA0" />

        </LinearLayout>
    </ScrollView>